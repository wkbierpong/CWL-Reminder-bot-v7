DISCORD_TOKEN=plak_hier_je_bot_token
DISCORD_CLIENT_ID=plak_hier_je_application_client_id
DISCORD_GUILD_ID=951865015126851584

# Gebruik role IDs als je die hebt. Namen werken ook, maar IDs zijn betrouwbaarder.
ALLOWED_ROLE_IDS=
ALLOWED_ROLE_NAMES=admins,co leider [BG1],co leider [BGX]

# Standaard: 2,5 seconde pauze tussen DM's, zodat Discord niet wordt gespamd.
DM_DELAY_MS=2500
MAX_DMS_PER_RUN=100

# Optioneel aanpassen. [Username], [PlayerName] en [PlayerTag] worden automatisch vervangen.
REMINDER_MESSAGE=Hoi [Username],\n\nWij zien dat je nog niet bent ingeschreven voor de Clan War League deze maand in Bruutgeweld!. We zijn deze maand begonnen met inschrijven i.p.v. standaard meedoen, dus even een persoonlijk bericht in het geval dat dit niet duidelijk was/of niet hebt meegekregen. Dit zullen wij in de toekomst blijven doen.\n\nDit bericht is geautomatiseerd, er waren veel mensen die bericht moesten worden, vraag in de server aan een co-leider als je hulp nodig hebt.
